@namespace Pixata.Blazor.Auditing.Components
@inject AuditViewerServiceInterface AuditViewerService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Routing
@using Pixata.Extensions.Auditing.Models
@using Pixata.Extensions.Auditing.Services
@using Pixata.Blazor.Auditing.Services
@implements IDisposable

<div class="audit-viewer">
  @if (_selectedEntityId is not null && _selectedEntityType is not null) {
    <div class="audit-history-view">
      <button class="back-btn" @onclick="BackToEntityList">← Back to entity list</button>
      <h3>Audit history for @_selectedEntityType.ShortName #@_selectedEntityId</h3>

      <div class="filters">
        <div class="filter-group">
          <label>From:</label>
          <input type="date" @bind="_filterFromDate" />
        </div>
        <div class="filter-group">
          <label>To:</label>
          <input type="date" @bind="_filterToDate" />
        </div>
        <div class="filter-group">
          <label>User:</label>
          <input type="text" @bind="_filterUser" placeholder="Filter by user..." />
        </div>
        <div class="filter-group">
          <label>Operation:</label>
          <select @bind="_filterOperation">
            <option value="">All</option>
            <option value="@AuditOperation.Created">Created</option>
            <option value="@AuditOperation.Updated">Updated</option>
            <option value="@AuditOperation.Deleted">Deleted</option>
          </select>
        </div>
        <button class="filter-btn" @onclick="ApplyFilters">Apply filters</button>
      </div>

      @if (_isLoadingHistory) {
        <div class="loading-state">
          <div class="spinner"></div>
          <span>Loading audit history…</span>
        </div>
      } else {
        <AuditTimeline Entries="_auditEntries"
                       DefaultHorizontalView="_defaultHorizontalView"
                       ShowOnlyChanged="_showOnlyChanged"
                       ShowOnlyChangedChanged="OnShowOnlyChangedChanged"
                       HorizontalView="_horizontalView"
                       HorizontalViewChanged="OnHorizontalViewChanged"
                       SelectedProperties="_selectedProperties"
                       SelectedPropertiesChanged="OnSelectedPropertiesChanged" />
      }
    </div>
  } else {
    <div class="entity-list-view">
      <div class="entity-type-selector">
        <label>Entity type:</label>
        <div class="entity-type-dropdown">
          <button class="entity-type-dropdown-btn" @onclick="ToggleEntityTypeDropdown">
            @GetEntityTypeSelectorLabel() ▾
          </button>
          @if (_entityTypeDropdownOpen) {
            <div class="entity-type-dropdown-backdrop" @onclick="CloseEntityTypeDropdown"></div>
            <div class="entity-type-dropdown-menu">
              <div class="entity-type-dropdown-actions">
                <button @onclick="CheckAllEntityTypes">Check all</button>
                <button @onclick="UncheckAllEntityTypes">Uncheck all</button>
              </div>
              <div class="entity-type-dropdown-item entity-type-all-item @(_showAllView ? "selected" : "")" @onclick="SelectAllView">
                All
              </div>
              @foreach (EntityTypeMetadata entityType in _entityTypes) {
                <label class="entity-type-dropdown-item @(!_showAllView && _selectedEntityTypeName == entityType.FullName ? "selected" : "")">
                  <input type="checkbox"
                         checked="@_checkedEntityTypes.Contains(entityType.FullName)"
                         @onchange="e => ToggleEntityTypeCheck(entityType.FullName, e)"
                         @onclick:stopPropagation />
                  <span @onclick="() => SelectSpecificEntityType(entityType)" @onclick:stopPropagation>@entityType.ShortName</span>
                </label>
              }
            </div>
          }
        </div>
      </div>

      @if (_isLoadingEntityTypes) {
        <div class="loading-state">
          <div class="spinner"></div>
          <span>Loading entity types…</span>
        </div>
      } else if (_showAllView) {
        <div class="all-audit-view">
          <div class="filters">
            <div class="filter-group">
              <label>From:</label>
              <input type="date" @bind="_allViewFilterFrom" />
            </div>
            <div class="filter-group">
              <label>To:</label>
              <input type="date" @bind="_allViewFilterTo" />
            </div>
            <div class="filter-group">
              <label>User:</label>
              <input type="text" @bind="_allViewFilterUser" placeholder="Filter by user..." />
            </div>
            <button class="filter-btn" @onclick="ApplyAllViewFilters">Apply filters</button>
          </div>

          @if (_isLoadingAllEntries) {
            <div class="loading-state">
              <div class="spinner"></div>
              <span>Loading audit entries…</span>
            </div>
          } else if (_filteredAllViewEntries.Count == 0) {
            <div class="empty-state">
              <span>📋</span>
              <p>No audit entries found.</p>
            </div>
          } else {
            <table class="entity-table all-audit-table">
              <thead>
                <tr>
                  <th>Entity Type</th>
                  <th>ID</th>
                  <th>Operation</th>
                  <th>Date</th>
                  <th>User</th>
                  <th>Changes</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                @foreach (AuditEntryViewModel entry in _pagedAllViewEntries) {
                  <tr>
                    <td>@GetEntityShortName(entry.EntityType)</td>
                    <td>@entry.EntityId</td>
                    <td><span class="operation-icon">@GetOperationIcon(entry.Operation)</span> @entry.Operation</td>
                    <td>@entry.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@entry.ChangedBy</td>
                    <td>
                      @if (_expandedAllViewEntries.Contains(entry.Id)) {
                        <button class="toggle-btn" @onclick="() => ToggleAllViewEntry(entry.Id)">▼ Hide properties</button>
                      } else {
                        <button class="toggle-btn" @onclick="() => ToggleAllViewEntry(entry.Id)">▶ Show properties (@GetAllViewPropertyCount(entry))</button>
                      }
                    </td>
                    <td>
                      <a class="view-btn" href="@GetAllViewEntityHistoryUrl(entry)">View history</a>
                    </td>
                  </tr>
                  @if (_expandedAllViewEntries.Contains(entry.Id)) {
                    <tr class="all-audit-expanded-row">
                      <td colspan="7">
                        <div class="properties-list">
                          @if (entry.Operation == AuditOperation.Created) {
                            @foreach (KeyValuePair<string, object?> prop in entry.Properties) {
                              <div class="property-row">
                                <span class="property-name">@prop.Key</span>
                                <span class="property-value">@prop.Value</span>
                              </div>
                            }
                          } else if (entry.ChangedProperties.Count > 0) {
                            @foreach (PropertyChange change in entry.ChangedProperties) {
                              <div class="property-row property-changed">
                                <span class="property-name">@change.PropertyName</span>
                                <div class="property-values">
                                  <span class="old-value">@change.OldValue</span>
                                  <span class="arrow">→</span>
                                  <span class="new-value">@change.NewValue</span>
                                </div>
                              </div>
                            }
                          } else {
                            @foreach (KeyValuePair<string, object?> prop in entry.Properties) {
                              <div class="property-row">
                                <span class="property-name">@prop.Key</span>
                                <span class="property-value">@prop.Value</span>
                              </div>
                            }
                          }
                        </div>
                      </td>
                    </tr>
                  }
                }
              </tbody>
            </table>
            @if (_allViewTotalPages > 1) {
              <div class="pagination">
                <button disabled="@(_allViewCurrentPage <= 1)" @onclick="AllViewPreviousPage">← Previous</button>
                <span>Page @_allViewCurrentPage of @_allViewTotalPages</span>
                <button disabled="@(_allViewCurrentPage >= _allViewTotalPages)" @onclick="AllViewNextPage">Next →</button>
              </div>
            }
          }
        </div>
      } else if (!string.IsNullOrWhiteSpace(_selectedEntityTypeName)) {
        <div class="entity-search">
          <input type="text" @bind="_searchTerm" @bind:after="LoadAuditedEntities" placeholder="Search by entity ID..." />
        </div>

        @if (_isLoadingEntities) {
          <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading entities…</span>
          </div>
        } else if (_auditedEntityIds.Count == 0) {
          <div class="empty-state">
            <span>📋</span>
            <p>No audited entities found for this type.</p>
          </div>
        } else {
          <table class="entity-table">
            <thead>
              <tr>
                <th>Entity ID</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              @foreach (string entityId in _pagedEntityIds) {
                <tr>
                  <td>@entityId</td>
                  <td>
                    <a class="view-btn" href="@GetEntityHistoryUrl(entityId)">View history</a>
                  </td>
                </tr>
              }
            </tbody>
          </table>
          @if (_totalPages > 1) {
            <div class="pagination">
              <button disabled="@(_currentPage <= 1)" @onclick="PreviousPage">← Previous</button>
              <span>Page @_currentPage of @_totalPages</span>
              <button disabled="@(_currentPage >= _totalPages)" @onclick="NextPage">Next →</button>
            </div>
          }
        }
      }
    </div>
  }
</div>

