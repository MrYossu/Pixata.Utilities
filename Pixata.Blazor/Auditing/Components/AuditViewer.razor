@code {

  [Parameter]
  public string? DefaultEntityType { get; set; }

  [Parameter]
  public bool DefaultHorizontalView { get; set; } = true;

  private bool _defaultHorizontalView = true;
  private bool _showOnlyChanged;
  private bool _horizontalView = true;
  private HashSet<string>? _selectedProperties;

  private List<EntityTypeMetadata> _entityTypes = [];
  private string? _selectedEntityTypeName;
  private EntityTypeMetadata? _selectedEntityType;
  private string? _selectedEntityId;
  private string _searchTerm = "";
  private bool _isLoadingEntityTypes;
  private bool _isLoadingEntities;
  private bool _isLoadingHistory;
  private bool _suppressLocationChanged;
  private List<string> _auditedEntityIds = [];
  private List<AuditEntryViewModel> _auditEntries = [];
  private int _currentPage = 1;
  private readonly int _pageSize = 20;
  private int _totalPages = 1;
  private DateTime? _filterFromDate;
  private DateTime? _filterToDate;
  private string? _filterUser;
  private AuditOperation? _filterOperation;

  // All-view state
  private bool _showAllView = true;
  private HashSet<string> _checkedEntityTypes = [];
  private bool _entityTypeDropdownOpen;
  private List<AuditEntryViewModel> _allViewEntries = [];
  private bool _isLoadingAllEntries;
  private DateTime? _allViewFilterFrom;
  private DateTime? _allViewFilterTo;
  private string? _allViewFilterUser;
  private HashSet<long> _expandedAllViewEntries = [];
  private int _allViewCurrentPage = 1;
  private int _allViewTotalPages = 1;

  private List<string> _pagedEntityIds =>
    _auditedEntityIds
      .Skip((_currentPage - 1) * _pageSize)
      .Take(_pageSize)
      .ToList();

  private List<AuditEntryViewModel> _filteredAllViewEntries =>
    _checkedEntityTypes.Count == 0 || _checkedEntityTypes.Count == _entityTypes.Count
      ? _allViewEntries
      : _allViewEntries.Where(e => _checkedEntityTypes.Contains(e.EntityType)).ToList();

  private List<AuditEntryViewModel> _pagedAllViewEntries =>
    _filteredAllViewEntries
      .Skip((_allViewCurrentPage - 1) * _pageSize)
      .Take(_pageSize)
      .ToList();

  protected override async Task OnInitializedAsync() {
    _defaultHorizontalView = DefaultHorizontalView;
    _horizontalView = DefaultHorizontalView;
    _isLoadingEntityTypes = true;
    _entityTypes = await AuditViewerService.GetEntityTypes();
    _isLoadingEntityTypes = false;

    // Default: all entity types checked
    _checkedEntityTypes = _entityTypes.Select(et => et.FullName).ToHashSet();

    // Default: show All view unless DefaultEntityType is specified
    if (!string.IsNullOrWhiteSpace(DefaultEntityType)) {
      _showAllView = false;
    }

    ReadQueryString();
    NavigationManager.LocationChanged += OnLocationChanged;

    if (_showAllView) {
      await LoadAllViewEntries();
    } else {
      if (_selectedEntityType is null && _entityTypes.Count > 0) {
        EntityTypeMetadata? defaultType = !string.IsNullOrWhiteSpace(DefaultEntityType)
          ? _entityTypes.FirstOrDefault(et => et.ShortName == DefaultEntityType || et.FullName == DefaultEntityType)
          : null;
        _selectedEntityType = defaultType ?? _entityTypes[0];
        _selectedEntityTypeName = _selectedEntityType.FullName;
      }

      if (_selectedEntityType is not null) {
        await LoadAuditedEntities();
        if (_selectedEntityId is not null) {
          await LoadAuditHistory();
        }
      }
    }
  }

  private void ReadQueryString() {
    Uri uri = new(NavigationManager.Uri);
    Dictionary<string, Microsoft.Extensions.Primitives.StringValues> query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

    if (query.TryGetValue("allView", out Microsoft.Extensions.Primitives.StringValues allViewValue)) {
      _showAllView = allViewValue != "false";
    } else if (query.ContainsKey("entityType") && !string.IsNullOrWhiteSpace(query["entityType"])) {
      _showAllView = false;
    }

    if (query.TryGetValue("checkedTypes", out Microsoft.Extensions.Primitives.StringValues checkedTypesValue) && !string.IsNullOrWhiteSpace(checkedTypesValue)) {
      _checkedEntityTypes = checkedTypesValue.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
    }

    if (query.TryGetValue("entityType", out Microsoft.Extensions.Primitives.StringValues entityTypeValue) && !string.IsNullOrWhiteSpace(entityTypeValue)) {
      _selectedEntityTypeName = entityTypeValue;
      _selectedEntityType = _entityTypes.FirstOrDefault(et => et.FullName == _selectedEntityTypeName);
    }

    if (query.TryGetValue("entityId", out Microsoft.Extensions.Primitives.StringValues entityIdValue) && !string.IsNullOrWhiteSpace(entityIdValue)) {
      _selectedEntityId = entityIdValue;
    }

    if (query.TryGetValue("page", out Microsoft.Extensions.Primitives.StringValues pageValue) && int.TryParse(pageValue, out int parsedPage) && parsedPage >= 1) {
      _currentPage = parsedPage;
    }

    if (query.TryGetValue("changedOnly", out Microsoft.Extensions.Primitives.StringValues changedOnlyValue)) {
      _showOnlyChanged = changedOnlyValue == "true";
    }

    if (query.TryGetValue("view", out Microsoft.Extensions.Primitives.StringValues viewValue)) {
      _horizontalView = viewValue == "horizontal";
      _defaultHorizontalView = _horizontalView;
    }

    if (query.TryGetValue("props", out Microsoft.Extensions.Primitives.StringValues propsValue) && !string.IsNullOrWhiteSpace(propsValue)) {
      _selectedProperties = propsValue.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
    }

    if (query.TryGetValue("allFrom", out Microsoft.Extensions.Primitives.StringValues allFromValue) && DateTime.TryParse(allFromValue, out DateTime parsedAllFrom)) {
      _allViewFilterFrom = parsedAllFrom;
    }

    if (query.TryGetValue("allTo", out Microsoft.Extensions.Primitives.StringValues allToValue) && DateTime.TryParse(allToValue, out DateTime parsedAllTo)) {
      _allViewFilterTo = parsedAllTo;
    }

    if (query.TryGetValue("allUser", out Microsoft.Extensions.Primitives.StringValues allUserValue) && !string.IsNullOrWhiteSpace(allUserValue)) {
      _allViewFilterUser = allUserValue;
    }

    if (query.TryGetValue("allPage", out Microsoft.Extensions.Primitives.StringValues allPageValue) && int.TryParse(allPageValue, out int parsedAllPage) && parsedAllPage >= 1) {
      _allViewCurrentPage = parsedAllPage;
    }
  }

  private void UpdateQueryString() {
    string? propsParam = null;
    if (_selectedProperties is not null && _selectedProperties.Count > 0) {
      propsParam = string.Join(",", _selectedProperties.OrderBy(p => p));
    }

    string? checkedTypesParam = null;
    if (_checkedEntityTypes.Count > 0 && _checkedEntityTypes.Count < _entityTypes.Count) {
      checkedTypesParam = string.Join(",", _checkedEntityTypes.OrderBy(t => t));
    }

    Dictionary<string, object?> parameters = new() {
      ["allView"] = _showAllView ? "true" : null,
      ["checkedTypes"] = checkedTypesParam,
      ["entityType"] = !_showAllView ? _selectedEntityTypeName : null,
      ["entityId"] = _selectedEntityId,
      ["page"] = !_showAllView && _currentPage > 1 ? _currentPage : null,
      ["changedOnly"] = _showOnlyChanged ? "true" : null,
      ["view"] = _horizontalView != DefaultHorizontalView ? (_horizontalView ? "horizontal" : "vertical") : null,
      ["props"] = propsParam,
      ["allFrom"] = _allViewFilterFrom.HasValue ? _allViewFilterFrom.Value.ToString("yyyy-MM-dd") : null,
      ["allTo"] = _allViewFilterTo.HasValue ? _allViewFilterTo.Value.ToString("yyyy-MM-dd") : null,
      ["allUser"] = !string.IsNullOrWhiteSpace(_allViewFilterUser) ? _allViewFilterUser : null,
      ["allPage"] = _showAllView && _allViewCurrentPage > 1 ? _allViewCurrentPage : null
    };

    string uri = NavigationManager.GetUriWithQueryParameters(parameters);
    NavigationManager.NavigateTo(uri, replace: true);
  }

  private async void OnLocationChanged(object? sender, LocationChangedEventArgs args) {
    if (_suppressLocationChanged) {
      _suppressLocationChanged = false;
      return;
    }
    ReadQueryString();
    if (_showAllView) {
      await LoadAllViewEntries();
    } else if (_selectedEntityType is not null) {
      await LoadAuditedEntities();
      if (_selectedEntityId is not null) {
        await LoadAuditHistory();
      }
    }
    await InvokeAsync(StateHasChanged);
  }

  public void Dispose() =>
    NavigationManager.LocationChanged -= OnLocationChanged;

  private void OnShowOnlyChangedChanged(bool value) {
    _showOnlyChanged = value;
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private void OnHorizontalViewChanged(bool value) {
    _horizontalView = value;
    _defaultHorizontalView = value;
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private void OnSelectedPropertiesChanged(HashSet<string> value) {
    _selectedProperties = value;
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private void CheckAllEntityTypes() {
    _checkedEntityTypes = _entityTypes.Select(et => et.FullName).ToHashSet();
    _allViewCurrentPage = 1;
    RecalcAllViewPages();
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private void UncheckAllEntityTypes() {
    _checkedEntityTypes.Clear();
    _allViewCurrentPage = 1;
    RecalcAllViewPages();
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private void ToggleEntityTypeDropdown() =>
    _entityTypeDropdownOpen = !_entityTypeDropdownOpen;

  private void CloseEntityTypeDropdown() =>
    _entityTypeDropdownOpen = false;

  private async Task SelectAllView() {
    _showAllView = true;
    _selectedEntityType = null;
    _selectedEntityTypeName = null;
    _selectedEntityId = null;
    _entityTypeDropdownOpen = false;
    _suppressLocationChanged = true;
    UpdateQueryString();
    await LoadAllViewEntries();
  }

  private async Task SelectSpecificEntityType(EntityTypeMetadata entityType) {
    _showAllView = false;
    _selectedEntityType = entityType;
    _selectedEntityTypeName = entityType.FullName;
    _selectedEntityId = null;
    _auditedEntityIds = [];
    _currentPage = 1;
    _totalPages = 1;
    _entityTypeDropdownOpen = false;
    _suppressLocationChanged = true;
    UpdateQueryString();
    await LoadAuditedEntities();
  }

  private void ToggleEntityTypeCheck(string fullName, ChangeEventArgs e) {
    if (e.Value is true) {
      _checkedEntityTypes.Add(fullName);
    } else {
      _checkedEntityTypes.Remove(fullName);
    }
    _allViewCurrentPage = 1;
    RecalcAllViewPages();
    _suppressLocationChanged = true;
    UpdateQueryString();
  }

  private async Task OnEntityTypeChanged() {
    _selectedEntityType = _entityTypes.FirstOrDefault(entityType => entityType.FullName == _selectedEntityTypeName);
    _selectedEntityId = null;
    _auditedEntityIds = [];
    _auditEntries = [];
    _currentPage = 1;
    _totalPages = 1;

    if (_selectedEntityType is not null) {
      await LoadAuditedEntities();
    }

    UpdateQueryString();
  }

  private async Task LoadAllViewEntries() {
    _isLoadingAllEntries = true;
    StateHasChanged();

    IEnumerable<string> typesToLoad = _entityTypes.Select(et => et.FullName);
    _allViewEntries = await AuditViewerService.GetAllAuditEntries(typesToLoad, _allViewFilterFrom, _allViewFilterTo, _allViewFilterUser);

    RecalcAllViewPages();

    _isLoadingAllEntries = false;
    StateHasChanged();
  }

  private void RecalcAllViewPages() {
    int count = _filteredAllViewEntries.Count;
    _allViewTotalPages = Math.Max(1, (int)Math.Ceiling(count / (double)_pageSize));
    if (_allViewCurrentPage > _allViewTotalPages) {
      _allViewCurrentPage = 1;
    }
  }

  private async Task ApplyAllViewFilters() {
    _allViewCurrentPage = 1;
    _suppressLocationChanged = true;
    UpdateQueryString();
    await LoadAllViewEntries();
  }

  private void ToggleAllViewEntry(long entryId) {
    if (!_expandedAllViewEntries.Remove(entryId)) {
      _expandedAllViewEntries.Add(entryId);
    }
  }

  private void AllViewPreviousPage() {
    if (_allViewCurrentPage > 1) {
      _allViewCurrentPage--;
      _suppressLocationChanged = true;
      UpdateQueryString();
    }
  }

  private void AllViewNextPage() {
    if (_allViewCurrentPage < _allViewTotalPages) {
      _allViewCurrentPage++;
      _suppressLocationChanged = true;
      UpdateQueryString();
    }
  }

  private async Task LoadAuditedEntities() {
    if (_selectedEntityType is null) {
      return;
    }

    _isLoadingEntities = true;
    StateHasChanged();

    _auditedEntityIds = await AuditViewerService.GetDistinctEntityIds(_selectedEntityType.FullName);

    if (!string.IsNullOrWhiteSpace(_searchTerm)) {
      _auditedEntityIds = _auditedEntityIds.Where(entityId => entityId.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    _totalPages = Math.Max(1, (int)Math.Ceiling(_auditedEntityIds.Count / (double)_pageSize));
    if (_currentPage > _totalPages) {
      _currentPage = 1;
    }

    _isLoadingEntities = false;
    StateHasChanged();
  }

  private string GetEntityHistoryUrl(string entityId) {
    Dictionary<string, object?> parameters = new() {
      ["allView"] = null,
      ["entityType"] = _selectedEntityTypeName,
      ["entityId"] = entityId,
      ["page"] = null
    };
    return NavigationManager.GetUriWithQueryParameters(parameters);
  }

  private string GetAllViewEntityHistoryUrl(AuditEntryViewModel entry) {
    Dictionary<string, object?> parameters = new() {
      ["allView"] = null,
      ["entityType"] = entry.EntityType,
      ["entityId"] = entry.EntityId,
      ["page"] = null
    };
    return NavigationManager.GetUriWithQueryParameters(parameters);
  }

  private async Task LoadAuditHistory() {
    if (_selectedEntityType is null || _selectedEntityId is null) {
      return;
    }

    _isLoadingHistory = true;
    StateHasChanged();

    _auditEntries = await AuditViewerService.GetAuditHistory(
      _selectedEntityType.FullName,
      _selectedEntityId,
      _filterFromDate,
      _filterToDate,
      _filterUser,
      _filterOperation);

    _isLoadingHistory = false;
    StateHasChanged();
  }

  private async Task ApplyFilters() =>
    await LoadAuditHistory();

  private void BackToEntityList() {
    _selectedEntityId = null;
    _auditEntries = [];
    _selectedProperties = null;
    _filterFromDate = null;
    _filterToDate = null;
    _filterUser = null;
    _filterOperation = null;
    UpdateQueryString();
  }

  private async Task PreviousPage() {
    if (_currentPage > 1) {
      _currentPage--;
      UpdateQueryString();
      await LoadAuditedEntities();
    }
  }

  private async Task NextPage() {
    if (_currentPage < _totalPages) {
      _currentPage++;
      UpdateQueryString();
      await LoadAuditedEntities();
    }
  }

  private string GetEntityTypeSelectorLabel() {
    if (!_showAllView) {
      return _selectedEntityType?.ShortName ?? "Select…";
    }
    if (_checkedEntityTypes.Count == 0) {
      return "None";
    }
    if (_checkedEntityTypes.Count == _entityTypes.Count) {
      return "All";
    }
    return string.Join(", ", _entityTypes.Where(et => _checkedEntityTypes.Contains(et.FullName)).Select(et => et.ShortName));
  }

  private string GetEntityShortName(string fullName) =>
    _entityTypes.FirstOrDefault(et => et.FullName == fullName)?.ShortName ?? fullName;

  private int GetAllViewPropertyCount(AuditEntryViewModel entry) =>
    entry.Operation == AuditOperation.Created || entry.ChangedProperties.Count == 0
      ? entry.Properties.Count
      : entry.ChangedProperties.Count;

  private static string GetOperationIcon(AuditOperation operation) => operation switch {
    AuditOperation.Created => "➕",
    AuditOperation.Updated => "✏️",
    AuditOperation.Deleted => "🗑️",
    _ => "❓"
  };

}
