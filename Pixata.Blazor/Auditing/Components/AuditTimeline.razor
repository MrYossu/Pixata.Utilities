@using Pixata.AspNetCore.Auditing.Models
@using Pixata.Blazor.Auditing.Models
@namespace Pixata.Blazor.Auditing.Components

<div class="audit-timeline">
  @if (Entries.Count == 0) {
    <div class="empty-state">
      <span>📋</span>
      <p>No audit entries found.</p>
    </div>
  } else {
    <div class="audit-timeline-controls">
      <label class="audit-toggle-label">
        <input type="checkbox" checked="@ShowOnlyChanged" @onchange="OnShowOnlyChangedToggled" />
        Show only changed properties
      </label>
      <div class="audit-property-filter">
        <button class="audit-property-filter-btn" @onclick="TogglePropertyDropdown">
          Properties (@_selectedProperties.Count/@GetAllPropertyNames().Count) ▾
        </button>
        @if (_propertyDropdownOpen) {
          <div class="audit-property-dropdown-backdrop" @onclick="ClosePropertyDropdown"></div>
          <div class="audit-property-dropdown">
            <div class="audit-property-dropdown-actions">
              <button @onclick="SelectAllProperties">Check all</button>
              <button @onclick="DeselectAllProperties">Uncheck all</button>
            </div>
            <div class="audit-property-dropdown-list">
              @foreach (string propertyName in GetAllPropertyNames()) {
                <label class="audit-property-dropdown-item">
                  <input type="checkbox" checked="@_selectedProperties.Contains(propertyName)" @onchange="e => ToggleProperty(propertyName, e)" />
                  @propertyName
                </label>
              }
            </div>
          </div>
        }
      </div>
      <div class="audit-view-toggle">
        <span class="audit-view-toggle-label">View:</span>
        <button class="audit-view-toggle-btn @(HorizontalView ? "" : "active")" @onclick="() => SetView(false)">Vertical</button>
        <button class="audit-view-toggle-btn @(HorizontalView ? "active" : "")" @onclick="() => SetView(true)">Horizontal</button>
      </div>
    </div>

    @if (HorizontalView) {
      <div class="audit-horizontal-scroll">
        <table class="audit-horizontal-table">
          <thead>
            <tr>
              <th class="audit-horizontal-property-col">Property</th>
              @foreach (AuditEntryViewModel entry in Entries) {
                <th>
                  <span class="operation-icon">@GetOperationIcon(entry.Operation)</span>
                  @entry.Operation
                  <br />
                  <span class="timestamp">@entry.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                  <br />
                  <span class="user">by @entry.ChangedBy</span>
                </th>
              }
            </tr>
          </thead>
          <tbody>
            @{
              HashSet<string> changedPropertyNames = GetChangedPropertyNames();
            }
            @foreach (string propertyName in GetAllPropertyNames()) {
              bool anyChanged = changedPropertyNames.Contains(propertyName);
              @if ((!ShowOnlyChanged || anyChanged) && _selectedProperties.Contains(propertyName)) {
                <tr>
                  <td class="audit-horizontal-property-col property-name">@propertyName</td>
                  @foreach (AuditEntryViewModel entry in Entries) {
                    PropertyChange? change = entry.ChangedProperties.FirstOrDefault(c => c.PropertyName == propertyName);
                    bool isCreated = entry.Operation == AuditOperation.Created;
                    @if (change is not null) {
                      <td class="property-changed">
                        @if (isCreated) {
                          <span class="new-value">@change.NewValue</span>
                        } else {
                          <span class="old-value">@change.OldValue</span>
                          <span class="arrow">→</span>
                          <span class="new-value">@change.NewValue</span>
                        }
                      </td>
                    } else if (isCreated && ShowOnlyChanged && anyChanged) {
                      entry.Properties.TryGetValue(propertyName, out object? val);
                      <td>@val</td>
                    } else if (!ShowOnlyChanged) {
                      entry.Properties.TryGetValue(propertyName, out object? val);
                      <td>@val</td>
                    } else {
                      <td></td>
                    }
                  }
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    } else {
      @foreach (AuditEntryViewModel entry in Entries) {
        <div class="timeline-entry">
          <div class="timeline-header">
            <span class="operation-icon">@GetOperationIcon(entry.Operation)</span>
            <span class="operation-label">@entry.Operation</span>
            <span class="timestamp">@entry.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
            <span class="user">by @entry.ChangedBy</span>
          </div>
          <div class="timeline-body">
            @if (_expandedEntries.Contains(entry.Id)) {
              <button class="toggle-btn" @onclick="() => ToggleEntry(entry.Id)">▼ Hide properties</button>
              <div class="properties-list">
                @{
                  HashSet<string> changedPropertyNames = entry.ChangedProperties.Select(change => change.PropertyName).ToHashSet();
                  bool isCreatedEntry = entry.Operation == AuditOperation.Created;
                }
                @foreach (KeyValuePair<string, object?> property in entry.Properties) {
                  bool isChanged = changedPropertyNames.Contains(property.Key);
                  @if (_selectedProperties.Contains(property.Key) && (!ShowOnlyChanged || isChanged || isCreatedEntry)) {
                    @if (isChanged) {
                      PropertyChange change = entry.ChangedProperties.First(changedProperty => changedProperty.PropertyName == property.Key);
                      <EntityPropertyDiff PropertyName="@property.Key" IsChanged="true" OldValue="@change.OldValue" NewValue="@change.NewValue" />
                    } else {
                      <EntityPropertyDiff PropertyName="@property.Key" Value="@(property.Value?.ToString())" />
                    }
                  }
                }
              </div>
            } else {
              <button class="toggle-btn" @onclick="() => ToggleEntry(entry.Id)">▶ Show properties (@GetVisiblePropertyCount(entry))</button>
              @if (entry.ChangedProperties.Count > 0) {
                <div class="changed-summary">
                  <span class="property-badge">🟡</span> @entry.ChangedProperties.Count changed: @string.Join(", ", entry.ChangedProperties.Select(change => change.PropertyName))
                </div>
              }
            }
          </div>
        </div>
      }
    }
  }
</div>

@code {
  [Parameter]
  public List<AuditEntryViewModel> Entries { get; set; } = [];

  [Parameter]
  public bool DefaultHorizontalView { get; set; } = true;

  [Parameter]
  public bool ShowOnlyChanged { get; set; }

  [Parameter]
  public EventCallback<bool> ShowOnlyChangedChanged { get; set; }

  [Parameter]
  public bool HorizontalView { get; set; } = true;

  [Parameter]
  public EventCallback<bool> HorizontalViewChanged { get; set; }

  [Parameter]
  public HashSet<string>? SelectedProperties { get; set; }

  [Parameter]
  public EventCallback<HashSet<string>> SelectedPropertiesChanged { get; set; }

  private HashSet<long> _expandedEntries = [];
  private HashSet<string> _selectedProperties = [];
  private bool _propertyDropdownOpen;
  private bool _initialized;
  private bool _propertiesInitialized;

  protected override void OnParametersSet() {
    if (!_initialized) {
      HorizontalView = DefaultHorizontalView;
      _initialized = true;
    }
    SyncSelectedProperties();
  }

  private void SyncSelectedProperties() {
    HashSet<string> allProperties = GetAllPropertyNames().ToHashSet();
    if (allProperties.Count == 0) {
      return;
    }
    if (!_propertiesInitialized) {
      // First time: use parent-supplied selection or select all
      _selectedProperties = SelectedProperties is not null && SelectedProperties.Count > 0
        ? new HashSet<string>(SelectedProperties.Where(p => allProperties.Contains(p)))
        : new HashSet<string>(allProperties);
      _propertiesInitialized = true;
    }
    // Remove properties that no longer exist in the data
    _selectedProperties.IntersectWith(allProperties);
  }

  private async Task OnShowOnlyChangedToggled(ChangeEventArgs e) {
    ShowOnlyChanged = e.Value is true;
    await ShowOnlyChangedChanged.InvokeAsync(ShowOnlyChanged);
  }

  private async Task SetView(bool horizontal) {
    HorizontalView = horizontal;
    await HorizontalViewChanged.InvokeAsync(HorizontalView);
  }

  private void ToggleEntry(long entryId) {
    if (!_expandedEntries.Remove(entryId)) {
      _expandedEntries.Add(entryId);
    }
  }

  private void TogglePropertyDropdown() =>
    _propertyDropdownOpen = !_propertyDropdownOpen;

  private void ClosePropertyDropdown() =>
    _propertyDropdownOpen = false;

  private async Task SelectAllProperties() {
    _selectedProperties = GetAllPropertyNames().ToHashSet();
    await SelectedPropertiesChanged.InvokeAsync(_selectedProperties);
  }

  private async Task DeselectAllProperties() {
    _selectedProperties.Clear();
    await SelectedPropertiesChanged.InvokeAsync(_selectedProperties);
  }

  private async Task ToggleProperty(string propertyName, ChangeEventArgs e) {
    if (e.Value is true) {
      _selectedProperties.Add(propertyName);
    } else {
      _selectedProperties.Remove(propertyName);
    }
    await SelectedPropertiesChanged.InvokeAsync(_selectedProperties);
  }

  private int GetVisiblePropertyCount(AuditEntryViewModel entry) {
    int count;
    if (!ShowOnlyChanged || entry.Operation == AuditOperation.Created) {
      count = entry.Properties.Count(p => _selectedProperties.Contains(p.Key));
    } else {
      count = entry.ChangedProperties.Count(c => _selectedProperties.Contains(c.PropertyName));
    }
    return count;
  }

  private List<string> GetAllPropertyNames() {
    HashSet<string> names = [];
    foreach (AuditEntryViewModel entry in Entries) {
      foreach (string key in entry.Properties.Keys) {
        names.Add(key);
      }
    }
    // Put "Id" (primary key) first, then sort the rest alphabetically
    return names
      .OrderBy(n => n.Equals("Id", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
      .ThenBy(n => n)
      .ToList();
  }

  private HashSet<string> GetChangedPropertyNames() {
    HashSet<string> names = [];
    foreach (AuditEntryViewModel entry in Entries) {
      if (entry.Operation == AuditOperation.Created) {
        continue;
      }
      foreach (PropertyChange change in entry.ChangedProperties) {
        names.Add(change.PropertyName);
      }
    }
    return names;
  }

  private static string GetOperationIcon(AuditOperation operation) => operation switch {
    AuditOperation.Created => "➕",
    AuditOperation.Updated => "✏️",
    AuditOperation.Deleted => "🗑️",
    _ => "❓"
  };
}
