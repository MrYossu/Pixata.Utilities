@if (string.IsNullOrWhiteSpace(SiteName)) {
  @ChildContent
} else {
  if (SiteNameAtEnd) {
    <PageTitle>@ChildContent @Separator @SiteName</PageTitle>
  } else {
    <PageTitle>@SiteName @Separator @ChildContent</PageTitle>
  }
}

@code {

  [Parameter]
  public RenderFragment ChildContent { get; set; }

  public static string SiteName = "";
  public static string Separator = "|";
  public static bool SiteNameAtEnd = true;

}