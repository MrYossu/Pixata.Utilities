@code {

  /// <summary>
  /// The list of policy names to evaluate against the current user.
  /// ASP.NET Core does not expose a way to enumerate all registered policies at runtime,
  /// so policy names must be supplied explicitly.
  /// </summary>
  [Parameter]
  public Type? PoliciesType { get; set; }

  private ClaimsPrincipal? _user;
  private List<Claim> _claims = [];
  private Dictionary<string, bool?> _policyResults = [];
  private bool _isLoading = true;

  protected override async Task OnInitializedAsync() {
    AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    _user = authState.User;

    if (_user.Identity?.IsAuthenticated == true) {
      _claims = [.. _user.Claims];
      await EvaluatePoliciesAsync();
    }

    _isLoading = false;
  }

  private async Task EvaluatePoliciesAsync() {
    _policyResults = [];

    List<string> policyNames = [];

    if (PoliciesType is not null) {
      policyNames = [..
        PoliciesType
          .GetFields(BindingFlags.Public | BindingFlags.Static)
          .Where(f => f.IsLiteral && !f.IsInitOnly && f.FieldType == typeof(string))
          .Select(f => (string)f.GetRawConstantValue()!)
      ];
    }

    foreach (string policyName in policyNames) {
      try {
        AuthorizationResult result = await AuthorizationService.AuthorizeAsync(_user!, policyName);
        _policyResults[policyName] = result.Succeeded;
      } catch (Exception) {
        _policyResults[policyName] = null;
      }
    }
  }

  private string FormatClaimType(string claimType) {
    // Shorten well-known long URIs for readability
    string[] segments = claimType.Split('/', '#', ':');
    return segments.Length > 1 ? segments[^1] : claimType;
  }

  private string GetInitials() {
    string name = _user?.Identity?.Name ?? string.Empty;
    string[] parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    return parts.Length switch {
      0 => "?",
      1 => parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant(),
      _ => $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
    };
  }

  private string GetPolicyClass(bool? result) => result switch {
    true => "pass",
    false => "fail",
    null => "unknown"
  };

}